    "@types/node": "^22.8.1",
    "@types/node-fetch": "^2.6.12",
    "@types/semver": "^7.5.8",
    "eslint": "^9.21.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.2",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.25.0"
  },
